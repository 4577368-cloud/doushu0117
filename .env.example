# ============================================
# 玄枢命理 — LLM 模型配置
# ============================================
# 使用方法：
#   1. 复制本文件为 .env.local
#   2. 填入真实的 Model ID 和 API Key
#   3. 本地开发：Vite 自动加载 .env.local
#   4. Vercel 部署：在 Project Settings → Environment Variables 中配置相同变量
#
# 调用逻辑：
#   分析 / 对话 / 报告生成时，按 LLM_1 → LLM_2 → LLM_3 优先级请求
#   当前模型超时或失败时，自动切换到下一个模型
# ============================================

# 单次请求超时（毫秒），超时后切换下一个模型
LLM_TIMEOUT_MS=45000

# ── 模型 1（默认优先）────────────────────────

LLM_MODEL1_LABEL=Gemma
LLM_MODEL1_BASE_URL=http://106.75.1.42:9017/v1
LLM_MODEL1_API_KEY=123456
LLM_MODEL1_MODEL_ID=Qwen3.5-27B

LLM_MODEL2_LABEL=MiniMax
LLM_MODEL2_BASE_URL=http://vllm.tangbuy.cn:8080/v1
LLM_MODEL2_API_KEY=123456
LLM_MODEL2_MODEL_ID=MiniMax-M2.1-AWQ


LLM_MODEL3_LABEL=Deepseek
LLM_MODEL3_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL3_API_KEY=sk-d45d9283527d4384b201e0bda7ec35ff
LLM_MODEL3_MODEL_ID=deepseek-chat
# ── BASE_URL 说明 ────────────────────────────
# 填写 API 根地址，系统会自动拼接 /chat/completions
#   DeepSeek:  https://api.deepseek.com
#   OpenAI:    https://api.openai.com/v1
#   其他兼容:  按服务商文档填写根地址即可

# ── 旧版兼容（可选，仅当上面三组均未配置时生效）──
# DEEPSEEK_API_KEY=sk-your-deepseek-key
