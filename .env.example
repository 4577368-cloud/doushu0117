# ============================================
# 玄枢命理 — 环境变量配置
# ============================================
# 使用方法：
#   1. 复制本文件为 .env.local
#   2. 填入真实值
#   3. 本地开发：Vite 自动加载 .env.local
#   4. Vercel 部署：在 Project Settings → Environment Variables 中配置
# ============================================

# ── Supabase（登录 / 档案云同步）──────────────
# 本地与 Vercel 均需配置，否则登录功能不可用
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── LLM 模型（按优先级 1 → 2 → 3 自动降级）──
LLM_TIMEOUT_MS=45000

# 模型 1（默认优先）
LLM_MODEL1_LABEL=主模型
LLM_MODEL1_MODEL_ID=your-model-id
LLM_MODEL1_API_KEY=your-api-key
LLM_MODEL1_BASE_URL=https://api.deepseek.com/v1

# 模型 2（第一备用）
LLM_MODEL2_LABEL=备用模型
LLM_MODEL2_MODEL_ID=your-model-id
LLM_MODEL2_API_KEY=your-api-key
LLM_MODEL2_BASE_URL=https://api.deepseek.com/v1

# 模型 3（最后兜底）
LLM_MODEL3_LABEL=兜底模型
LLM_MODEL3_MODEL_ID=your-model-id
LLM_MODEL3_API_KEY=your-api-key
LLM_MODEL3_BASE_URL=https://api.openai.com/v1

# BASE_URL 填写 API 根地址，系统自动拼接 /chat/completions
#   DeepSeek:  https://api.deepseek.com  或  https://api.deepseek.com/v1
#   OpenAI:    https://api.openai.com/v1
#   自建 vLLM: http://your-host:port/v1

# 也支持 LLM_1_NAME / LLM_1_MODEL_ID 等命名（与 LLM_MODEL1_* 二选一）
